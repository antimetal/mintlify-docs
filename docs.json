{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "custom": {
    "css": "/custom.css"
  },
  "name": "Antimetal Docs",
  "colors": {
    "primary": "#000000",
    "light": "#DBEF01",
    "dark": "#000000"
  },
  "fonts": {
    "heading": {
      "family": "Ivar Text",
      "source": "/fonts/IvarText-Regular.woff2",
      "format": "woff2"
    },
    "body": {
      "family": "ABC Diatype Plus Variable",
      "source": "/fonts/ABCDiatypePlusVariable-fixed.woff2",
      "format": "woff2"
    }
  },
  "favicon": {
    "light": "/favicon-light.png",
    "dark": "/favicon-dark.png"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quick-start", "connect"]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/overview",
              {
                "group": "Monitoring and Observability",
                "pages": [
                  "integrations/datadog",
                  "integrations/grafana-cloud",
                  "integrations/sentry"
                ]
              },
              {
                "group": "Cloud and Infrastructure",
                "pages": [
                  "integrations/cloudwatch",
                  "integrations/gcp",
                  "integrations/vercel"
                ]
              },
              {
                "group": "Incident Management",
                "pages": ["integrations/pagerduty", "integrations/incident-io"]
              },
              {
                "group": "Source Control",
                "pages": ["integrations/github"]
              },
              {
                "group": "Chat",
                "pages": ["integrations/slack"]
              }
            ]
          },
          {
            "group": "Product Guide",
            "pages": [
              "product/search",
              "product/issue-lifecycle",
              "product/skills"
            ]
          },
          {
            "group": "Admin",
            "pages": ["admin/security"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": {
          "source": "/assets/openapi.mintlify.json"
        }
      }
    ],
    "global": {}
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Log in",
        "href": "https://overlook.antimetal.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Book a Demo",
      "href": "https://antimetal.com/demo"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/antimetal",
      "github": "https://github.com/antimetal",
      "linkedin": "https://www.linkedin.com/company/antimetal"
    }
  }
}
