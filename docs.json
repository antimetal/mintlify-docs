{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Antimetal Docs",
  "colors": {
    "primary": "#000000",
    "light": "#DBEF01",
    "dark": "#000000"
  },
  "fonts": {
    "heading": {
      "family": "Ivar Text",
      "source": "/fonts/IvarText-Regular.woff2",
      "format": "woff2"
    },
    "body": {
      "family": "ABC Diatype Plus Variable",
      "source": "/fonts/ABCDiatypePlusVariable-fixed.woff2",
      "format": "woff2"
    }
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "mcp"]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/overview",
              {
                "group": "Monitoring and Observability",
                "pages": [
                  "integrations/datadog",
                  "integrations/grafana-cloud",
                  "integrations/sentry"
                ]
              },
              {
                "group": "Cloud and Infrastructure",
                "pages": [
                  "integrations/cloudwatch",
                  "integrations/gcp"
                ]
              },
              {
                "group": "Incident Management",
                "pages": [
                  "integrations/pagerduty",
                  "integrations/incident-io"
                ]
              },
              {
                "group": "Source Control",
                "pages": [
                  "integrations/github"
                ]
              },
              {
                "group": "Chat",
                "pages": [
                  "integrations/slack"
                ]
              }
            ]
          },
          {
            "group": "Admin",
            "pages": [
              "admin/security"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": {
          "source": "/assets/openapi.mintlify.json"
        }
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "href": "https://antimetal.com/resources/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Log in",
        "href": "https://overlook.antimetal.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Book a Demo",
      "href": "https://antimetal.com/demo"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/antimetal",
      "github": "https://github.com/antimetal",
      "linkedin": "https://www.linkedin.com/company/antimetal"
    }
  }
}
